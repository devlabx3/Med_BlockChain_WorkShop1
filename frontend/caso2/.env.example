# Configuración para el Taller de Monad Blitz
# Copia este archivo como .env en las carpetas frontend/caso1, frontend/caso2 y frontend/caso3

# Obtén tu Project ID en https://cloud.reown.com/
VITE_WALLETCONNECT_PROJECT_ID=tu_project_id_aqui

# URL del nodo RPC de Monad Testnet
VITE_MONAD_RPC_URL=https://testnet-rpc.monad.xyz/

# Direcciones de los contratos desplegados en Monad Testnet vía Remix
# Despliega Storage.sol y pega la dirección aquí
VITE_STORAGE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Despliega TodoList.sol y pega la dirección aquí
VITE_TODOLIST_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
